# Required CookMyBots X proxy settings
COOKMYBOTS_X_ENDPOINT=https://api.cookmybots.com/api/x
COOKMYBOTS_X_KEY=

# Required MongoDB persistence
MONGODB_URI=mongodb+srv://user:password@cluster.example.net/sentiment-sentinel

# Monitoring targets, comma-separated. Leave blank to start safely without polling work.
X_MONITOR_KEYWORDS=$TOKEN,#TokenName,TokenName
X_MONITOR_ACCOUNTS=officialAccount,founderAccount

# Polling and reporting
X_POLL_INTERVAL_SECONDS=300
X_REPORT_INTERVAL_HOURS=6

# Spike detection
X_SPIKE_WINDOW_MINUTES=60
X_SPIKE_VOLUME_MULTIPLIER=3
X_SPIKE_NEGATIVE_SHARE_THRESHOLD=0.5

# Posting safety toggles
X_POST_REPORTS=false
X_POST_ALERTS=false
X_DRY_RUN=true
